generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String?
  username        String
  nickname        String?
  membership      Membership       @default(FREE)
  roles           String[]         @default(["USER"])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  provider        String?
  providerId      String?
  credits         Int              @default(0)
  creditPurchases CreditPurchase[]
  favorites       Favorite[]
  paymentMethods  PaymentMethod[]
  recommendations Recommendation[]
  subscriptions   Subscription[]
  stickers        UserSticker[]

  @@unique([provider, providerId])
  @@map("users")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  membership           Membership
  interval             BillingInterval
  price                Int
  billingKey           String?
  nextBillingDate      DateTime?
  status               SubscriptionStatus @default(ACTIVE)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  stripeCustomerId     String?
  stripeSubscriptionId String?
  lastPaymentKey       String?
  lastOrderId          String?
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("subscriptions")
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  billingKey  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customerKey String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

model Recommendation {
  id           String   @id @default(cuid())
  userId       String?
  imageUrl     String?
  occasion     String
  tastes       String[]
  drinks       Json
  fairyMessage String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("recommendations")
}

model Drink {
  id           String   @id @default(cuid())
  name         String
  nameKo       String?
  type         String
  description  String
  tastingNotes String[]
  image        String?
  price        String
  foodPairings String[]
  occasions    String[]
  tastes       String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  purchaseUrl  String?

  @@index([type])
  @@map("drinks")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  drinkId    String
  drinkName  String
  drinkType  String
  drinkImage String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, drinkId])
  @@map("favorites")
}

model SupportMessage {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  message   String
  createdAt DateTime @default(now())

  @@map("support_messages")
}

model Payment {
  id         String        @id @default(cuid())
  userId     String
  paymentKey String        @unique
  orderId    String        @unique
  amount     Int
  status     PaymentStatus
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([userId])
  @@map("payments")
}

model CreditPurchase {
  id          String        @id @default(cuid())
  userId      String
  packageType String
  credits     Int
  price       Int
  paymentKey  String?
  orderId     String        @unique
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_purchases")
}

model UserSticker {
  id         String   @id @default(cuid())
  userId     String
  stickerId  String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stickerId])
  @@map("user_stickers")
}

model AiRecommendationCache {
  id              String   @id @default(cuid())
  foodKeywords    String[]
  foodCategory    String
  occasion        String?
  tastes          String[]
  cacheKey        String   @unique
  recommendations Json
  fairyMessage    String
  hitCount        Int      @default(0)
  lastUsedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([cacheKey])
  @@index([foodCategory, occasion])
  @@map("ai_recommendation_cache")
}

enum Membership {
  FREE
  PREMIUM
}

enum BillingInterval {
  MONTHLY
  ANNUALLY
  WEEKLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  FAILED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}
