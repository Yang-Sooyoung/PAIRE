# Force UTF-8 for all text files - prevents Korean encoding corruption
* text=auto eol=lf
*.ts text eol=lf encoding=utf-8
*.tsx text eol=lf encoding=utf-8
*.js text eol=lf encoding=utf-8
*.jsx text eol=lf encoding=utf-8
*.json text eol=lf encoding=utf-8
*.css text eol=lf encoding=utf-8
*.md text eol=lf encoding=utf-8
*.gradle text eol=lf
*.xml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.aab binary
*.apk binary
*.jks binary
*.keystore binary
*.jar binary
